  <!-- Toolbox Features -->
  <string name="title_create_sta">Create STA</string>
  <string name="desc_create_sta">
    Create STA (Switch to Android) is a feature that allows you to seamlessly switch
    from Windows to Android OS with just one click. This feature ensures a smooth transition
    without requiring complex configurations, making it easy to boot into Android directly
    from Windows.
  </string>

  <string name="sta_creation_failed">Failed to create STA environment</string>
  <string name="title_arm_software">ARM Software</string>
  <string name="desc_arm_software">
    This option adds browser shortcuts to Desktop/ARMSoftware, providing quick access to a curated
    collection of ARM-compatible software. These tools are specifically designed to enhance
    performance and functionality when running Windows on ARM-based devices.
  </string>

  <string name="modem_provision_success">Modem provisioning completed successfully</string>
  <string name="modem_provision_partial">Modem provisioning partially completed</string>
  <string name="modem_provision_failed">Modem provisioning failed</string>

  <string name="title_atlas_revi_os">Atlas OS / Revi OS</string>
  <string name="desc_atlas_revi_os">
    Download and add essential resources for AtlasOS and ReviOS, including playbooks and
    AME Wizard, to Desktop. These optimized Windows distributions help improve performance
    and remove unnecessary bloat, making your system faster and more efficient.
  </string>

  <string name="title_script_toolbox">Script Toolbox</string>
  <string name="desc_script_toolbox">
    The Script Toolbox provides a collection of automation scripts and system tweaks
    to optimize Windows performance. These scripts help automate repetitive tasks,
    enhance system stability, and improve overall efficiency.
  </string>

  <string name="title_download_frameworks">Download Frameworks</string>
  <string name="desc_download_frameworks">
    Easily download and install essential frameworks for Windows. These frameworks
    include necessary dependencies and libraries required for running various applications,
    improving compatibility, and ensuring smoother software execution.
  </string>

