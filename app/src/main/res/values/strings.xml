    <!-- ==================== TOOLBOX FEATURES ==================== -->
    <!-- Create STA -->
    <string name="title_create_sta">Create STA</string>
    <string name="desc_create_sta">Create STA (Switch to Android) is a feature that allows you to seamlessly switch from Windows to Android OS with just one click. This feature ensures a smooth transition without requiring complex configurations, making it easy to boot into Android directly from Windows.</string>

